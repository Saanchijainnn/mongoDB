<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white px-10 py-10">
        <a href="/" class="text-blue-500 mt-10">Back to Home</a>
        <h1 class="text-3xl tracking-tight mb-5">All Users</h1>

        <div class="users flex flex-wrap gap-3">

            <% if(users.length > 0){ %>
                <% users.forEach(function(user){ %>
            <div class="user w-64 p-4 bg-zinc-800 rounded-lg">
                <div class="w-full h-40 rounded-lg bg-zinc-700 overflow-hidden">

                    <img src="<%=user.image%>" class="w-full h-full object-cover rounded-lg">
                </div>

                <h3 class="mt-3 text-base font-medium tracking-tight">
                    <%=user.name%>
                </h3>

                <h5 class="text-sm text-zinc-500">
                    <%=user.email%>
                </h5>

                <div class="flex gap-3 mt-4 text-sm">
                    <a href="/edit/<%=user._id%>" class="text-blue-500">Edit User</a>
                    <a href="/delete/<%=user._id%>" class="text-red-500">Delete User</a>
                </div>
            </div>
            <% }) %>
            <% } else { %>
            <h3 class="text-lg text-zinc-500">No users yet </h3>
            <% } %>

        </div>
    </div>
</body>
</html>