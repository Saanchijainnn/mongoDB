<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-800 p-10 text-white">
        <div class="nav mb-10">
            <a href="/read" class="text-blue-500 ">Read Users</a> 
            
            </div>
        <h1 class="text-3xl tracking-tighter mb-3">Update User</h1>

        <form action="/update/<%=user._id%>" method="post" class="flex gap-3 items-center">
            <input 
                type="text" 
                name="name" 
                placeholder="name" 
                value="<%=user.name%>"
                class="bg-transparent px-5 py-2 rounded-lg border-2 border-zinc-600 outline-none"
            >

            <input 
                type="email" 
                name="email" 
                placeholder="email" 
                value="<%=user.email%>"
                class="bg-transparent px-5 py-2 rounded-lg border-2 border-zinc-600 outline-none"
            >

            <input 
                type="text" 
                name="image" 
                placeholder="image url" 
                value="<%=user.image%>"
                class="bg-transparent px-5 py-2 rounded-lg border-2 border-zinc-600 outline-none"
            >

            <input
                value="Update User"
                type="submit"
                class="bg-yellow-500 ml-3 text-black px-5 py-2 rounded-lg  "
            >
            </input>
        </form>
    </div>
</body>
</html>