<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-800 p-10 text-white">
        <h1 class="text-3xl tracking-tighter mb-3">Create User</h1>

        <form action="" class="flex gap-3 items-center">
            <input 
                type="text" 
                name="name" 
                placeholder="name" 
                class="bg-transparent px-5 py-2 rounded-lg border-2 border-zinc-600 outline-none"
            >

            <input 
                type="email" 
                name="email" 
                placeholder="email" 
                class="bg-transparent px-5 py-2 rounded-lg border-2 border-zinc-600 outline-none"
            >

            <input 
                type="text" 
                name="image" 
                placeholder="image url" 
                class="bg-transparent px-5 py-2 rounded-lg border-2 border-zinc-600 outline-none"
            >

            <input
                value="create user"
                type="submit"
                class="bg-blue-600 ml-3 px-5 py-2 rounded-lg  "
            >
            </input>
        </form>
    </div>
</body>
</html>